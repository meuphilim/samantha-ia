 void ThreadPool::worker(bool is_dynamic) {
+#ifndef _WIN32
+  // Block every signal on this thread so pthread_cond_timedwait() can't
+  // be interrupted with EINTR (libcxx rethrows EINTR as std::system_error
+  // and std::terminates the process). Keep synchronous fault signals
+  // deliverable so real crashes still surface.
+  sigset_t block_mask;
+  sigfillset(&block_mask);
+  sigdelset(&block_mask, SIGSEGV);
+  sigdelset(&block_mask, SIGBUS);
+  sigdelset(&block_mask, SIGILL);
+  sigdelset(&block_mask, SIGFPE);
+  sigdelset(&block_mask, SIGABRT);
+  sigdelset(&block_mask, SIGSYS);
+  sigdelset(&block_mask, SIGTRAP);
+  pthread_sigmask(SIG_BLOCK, &block_mask, nullptr);
+#endif
   for (;;) {
     std::function<void()> fn;
     {
@@ -6308,7 +6324,13 @@ void ThreadPool::worker(bool is_dynamic) {
           break;
         }
       } else {
-        cond_.wait(lock, [&] { return !jobs_.empty() || shutdown_; });
+        // Use wait_for() instead of wait() to work around a
+        // Cosmopolitan libc bug where untimed futex waits on XNU
+        // (macOS) expire after ~72 minutes, causing
+        // condition_variable::wait() to throw ETIMEDOUT.
+        while (jobs_.empty() && !shutdown_) {
+          cond_.wait_for(lock, std::chrono::seconds(30));
+        }
       }
 
       idle_thread_count_--;
